{
  "name": "leviosa-konva",
  "version": "0.0.1",
  "description": "Shared carousel block→react-konva render core. Single source of truth for the editor (leviosa-frontend) and the headless renderer (leviosa-rendering-server) so the editor is pixel-identical to published output.",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "konva": "^9.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "konva": "9.3.18",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-konva": "19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
