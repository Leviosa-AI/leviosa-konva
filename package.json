{
  "name": "@leviosa-ai/konva",
  "version": "0.4.5",
  "description": "Shared carousel block→react-konva render core AND the canonical font bundle. Single source of truth for the editor (leviosa-frontend) and the headless renderer (leviosa-rendering-server) so the editor is pixel-identical to published output. Consumers MUST NOT fetch fonts independently — they copy the woff2 bytes from this package and generate CSS via scripts/gen-font-css.mjs.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leviosa-AI/leviosa-konva.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "leviosa-konva-fonts": "scripts/gen-font-css.mjs"
  },
  "files": [
    "dist",
    "src",
    "fonts",
    "scripts/gen-font-css.mjs"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup",
    "fonts:freeze": "node scripts/freeze-fonts.mjs",
    "fonts:gen": "node scripts/gen-font-css.mjs"
  },
  "peerDependencies": {
    "konva": "^9.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "konva": "9.3.18",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-konva": "19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
